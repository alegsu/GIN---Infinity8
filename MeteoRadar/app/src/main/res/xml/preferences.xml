<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- POSIZIONE -->
    <PreferenceCategory android:title="Posizione">

        <SwitchPreferenceCompat
            android:key="use_gps"
            android:title="Usa GPS"
            android:summary="Rileva automaticamente la posizione corrente"
            android:defaultValue="true" />

        <EditTextPreference
            android:key="manual_lat"
            android:title="Latitudine manuale"
            android:summary="Usata quando il GPS è disattivato"
            android:defaultValue="41.9028"
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            android:key="manual_lon"
            android:title="Longitudine manuale"
            android:summary="Usata quando il GPS è disattivato"
            android:defaultValue="12.4964"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            android:key="radius_km"
            android:title="Raggio di monitoraggio"
            android:summary="Cerca il peggior scenario entro questo raggio"
            android:entries="@array/radius_entries"
            android:entryValues="@array/radius_values"
            android:defaultValue="0"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

    <!-- PREVISIONI -->
    <PreferenceCategory android:title="Previsioni">

        <ListPreference
            android:key="forecast_hours"
            android:title="Ore previsione oraria"
            android:summary="Quante ore visualizzare nel tab Previsioni"
            android:entries="@array/forecast_hours_entries"
            android:entryValues="@array/forecast_hours_values"
            android:defaultValue="24"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            android:key="show_tech_details"
            android:title="Mostra dettagli tecnici"
            android:summary="CAPE, Lifted Index, livello zero, raffiche"
            android:defaultValue="false" />

    </PreferenceCategory>

    <!-- NOTIFICHE -->
    <PreferenceCategory android:title="Notifiche">

        <SwitchPreferenceCompat
            android:key="notifications_enabled"
            android:title="Abilita notifiche"
            android:summary="Invia avvisi per eventi meteo significativi"
            android:defaultValue="true" />

        <ListPreference
            android:key="check_interval_min"
            android:title="Frequenza controllo"
            android:summary="Ogni quanto controllare le condizioni meteo"
            android:entries="@array/interval_entries"
            android:entryValues="@array/interval_values"
            android:defaultValue="30"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            android:key="alert_threshold"
            android:title="Soglia allerta"
            android:summary="Score minimo per ricevere notifica"
            android:entries="@array/threshold_entries"
            android:entryValues="@array/threshold_values"
            android:defaultValue="3"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            android:key="vibration"
            android:title="Vibrazione"
            android:summary="Vibra con la notifica di allerta"
            android:defaultValue="true" />

    </PreferenceCategory>

    <!-- INFO -->
    <PreferenceCategory android:title="Informazioni">

        <Preference
            android:key="version_info"
            android:title="Versione app"
            android:selectable="false" />

        <Preference
            android:key="data_source"
            android:title="Fonte dati"
            android:summary="Open-Meteo.com — GFS + ECMWF + ICON, aggiornati ogni ora"
            android:selectable="false" />

        <Preference
            android:key="open_help"
            android:title="📖  Guida all\'app"
            android:summary="Come funziona lo score, le previsioni, lo storico e le notifiche" />

    </PreferenceCategory>

</PreferenceScreen>
