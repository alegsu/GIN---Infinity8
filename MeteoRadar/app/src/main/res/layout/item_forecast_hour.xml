<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:paddingEnd="8dp">

    <!-- Severity color strip -->
    <View
        android:id="@+id/severityStrip"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="10dp" />

    <!-- Weather emoji -->
    <TextView
        android:id="@+id/tvEmoji"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:textSize="20sp"
        android:gravity="center"
        android:layout_marginEnd="6dp" />

    <!-- Time -->
    <TextView
        android:id="@+id/tvTime"
        android:layout_width="44dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Content: description + badge + score bar + tech -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="6dp"
        android:orientation="vertical">

        <!-- Row 1: description + severity badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvSeverity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="7dp"
                android:paddingRight="7dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Row 2: score bar + score text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <ProgressBar
                android:id="@+id/scoreBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="5dp"
                android:layout_weight="1"
                android:max="15"
                android:progress="0" />

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:gravity="end"
                android:text="0/15" />

        </LinearLayout>

        <!-- Row 3: technical details (shown when setting enabled) -->
        <TextView
            android:id="@+id/tvTech"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

    </LinearLayout>
</LinearLayout>
